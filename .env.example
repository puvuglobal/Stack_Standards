# Stack Standards Environment Template
# Copy this to .env.local and fill in your values

# ===========================================
# SUPABASE CONFIGURATION
# ===========================================

# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon key (safe to expose in client)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key (SERVER-SIDE ONLY - NEVER expose in client)
# This goes in .env, NOT .env.local
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ===========================================
# AUTHENTICATION
# ===========================================

# Auth settings
NEXT_PUBLIC_AUTH_EXPIRY_HOURS=168  # 7 days
NEXT_PUBLIC_SESSION_REFRESH_MINUTES=60

# Password policy
NEXT_PUBLIC_PASSWORD_MIN_LENGTH=16
NEXT_PUBLIC_PASSWORD_REQUIRE_UPPERCASE=true
NEXT_PUBLIC_PASSWORD_REQUIRE_LOWERCASE=true
NEXT_PUBLIC_PASSWORD_REQUIRE_NUMBER=true
NEXT_PUBLIC_PASSWORD_REQUIRE_SPECIAL=true

# ===========================================
# ROLE CONFIGURATION
# ===========================================

NEXT_PUBLIC_ROLES=candidate,client,admin
NEXT_PUBLIC_DEFAULT_ROLE=candidate

# Role display names
NEXT_PUBLIC_ROLE_CANDIDATE_DISPLAY=Candidate
NEXT_PUBLIC_ROLE_CLIENT_DISPLAY=VIP Client

# ===========================================
# APPLICATION URLs
# ===========================================

# Your Vercel deployment URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL_PRODUCTION=https://your-domain.com

# Auth redirect URLs
NEXT_PUBLIC_AUTH_REDIRECT_URL=http://localhost:3000/auth/callback
NEXT_PUBLIC_AUTH_REDIRECT_URL_PRODUCTION=https://your-domain.com/auth/callback

# ===========================================
# FILE STORAGE
# ===========================================

NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET_AVATARS=avatars
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET_DOCUMENTS=documents
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET_CONTRACTS=contracts
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET_TRAININGS=trainings

# Max file sizes (in bytes)
NEXT_PUBLIC_MAX_FILE_SIZE=5242880  # 5MB
NEXT_PUBLIC_MAX_IMAGE_SIZE=2097152  # 2MB

# ===========================================
# API CONFIGURATION
# ===========================================

# API Rate limiting
NEXT_PUBLIC_RATE_LIMIT_MAX_REQUESTS=100
NEXT_PUBLIC_RATE_LIMIT_WINDOW_MS=60000

# Pagination
NEXT_PUBLIC_DEFAULT_PAGE_SIZE=20
NEXT_PUBLIC_MAX_PAGE_SIZE=100

# ===========================================
# FEATURES
# ===========================================

NEXT_PUBLIC_FEATURE_REALTIME_ENABLED=true
NEXT_PUBLIC_FEATURE_DOCUMENTATION_TIMER=true
NEXT_PUBLIC_FEATURE_VIDEO_TRAINING=true
NEXT_PUBLIC_FEATURE_CONTRACTS=true

# ===========================================
# DOCUMENTATION STAGES
# ===========================================

NEXT_PUBLIC_DOCUMENTATION_STAGES=Document Validation,Background Check,Skill Validation,Education Validation,Visa Expiration

# ===========================================
# LEGAL/JURISDICTIONS
# ===========================================

NEXT_PUBLIC_LEGAL_JURISDICTIONS=US-Federal,US-AL,US-AK,US-AZ,US-AR,US-CA,US-CO,US-CT,US-DE,US-FL,US-GA,US-HI,US-ID,US-IL,US-IN,US-IA,US-KS,US-KY,US-LA,US-ME,US-MD,US-MA,US-MI,US-MN,US-MS,US-MO,US-MT,US-NE,US-NV,US-NH,US-NJ,US-NM,US-NY,US-NC,US-ND,US-OH,US-OK,US-OR,US-PA,US-RI,US-SC,US-SD,US-TN,US-TX,US-UT,US-VT,US-VA,US-WA,US-WV,US-WI,US-WY

# ===========================================
# DEBUG & DEVELOPMENT
# ===========================================

NODE_ENV=development
NEXT_PUBLIC_DEBUG_MODE=false
NEXT_PUBLIC_LOG_LEVEL=warn

# ===========================================
# SECURITY HEADERS (Configured in next.config.js)
# ===========================================

# Content Security Policy
NEXT_PUBLIC_CSP_DEFAULT_SRC="'self'"
NEXT_PUBLIC_CSP_SCRIPT_SRC="'self' 'unsafe-inline' 'unsafe-eval'"
NEXT_PUBLIC_CSP_STYLE_SRC="'self' 'unsafe-inline'"
NEXT_PUBLIC_CSP_IMG_SRC="'self' data: https:"
NEXT_PUBLIC_CSP_CONNECT_SRC="'self' https://*.supabase.co wss://*.supabase.co"
